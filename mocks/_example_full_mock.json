{
  "name": "example-full-mock",
  "enabled": false,
  "match": { "url_pattern": ".*/sse.*" },
  "mode": "full_mock",
  "pipeline": [
    {
      "action": "mock",
      "event": "status",
      "data": "{\"status\":\"SEARCHING\",\"progress\":0}"
    },
    { "action": "delay", "delay_ms": 1000 },
    {
      "action": "mock",
      "event": "status",
      "data": "{\"status\":\"SEARCHING\",\"progress\":50}"
    },
    { "action": "delay", "delay_ms": 1000 },
    {
      "action": "mock",
      "event": "result",
      "data": "{\"status\":\"COMPLETE\",\"results\":[{\"id\":\"FL001\",\"price\":1500000}]}"
    }
  ]
}
