{
  "name": "example-inject-error",
  "enabled": false,
  "match": { "url_pattern": ".*/sse.*" },
  "mode": "pipeline",
  "pipeline": [
    { "action": "passthrough" },
    { "action": "passthrough" },
    {
      "action": "mock",
      "event": "error",
      "data": "{\"code\":\"UPSTREAM_ERROR\",\"message\":\"Simulated server error\"}"
    },
    { "action": "drop_rest" }
  ]
}
